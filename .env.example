# Supabase project URL, for browser and server Supabase clients.
NEXT_PUBLIC_SUPABASE_URL=

# Supabase anon key, safe for browser usage with Row Level Security.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service role key. Keep secret. Required for demo seeders, resets,
# recurring-expense cron processing, and admin-only server operations.
SUPABASE_SERVICE_ROLE_KEY=

# Canonical app URL used for auth redirects and invite/share links.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional bearer token for /api/cron/recurring-expenses. If empty, the route
# runs without an Authorization header check.
CRON_SECRET=
